<Window x:Class="ChatBot_POE_2.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ChatBot_POE_2"
        mc:Ignorable="d"
        Title="MainWindow" Height="450" Width="800">
    <Grid Background="#001F3F" >

        <!-- Home Grid-->
        <Grid x:Name="home_grid" Visibility="Visible">

            <!-- Logo -->
            <Image 
                Source="/Logo50.jpg" 
                Height="200"
                Width="800"
                Margin="0,0,0,200"
                   />

            <!-- welcome message-->
            <TextBlock
                Foreground="#1DA1FF" 
                Text="Welcome to Cybersecurity Awareness chatbot"
                FontSize="14"
                
                Height="20"
                Width="300"
                TextAlignment="Center"
                Margin="0,30,0,0"
                FontFamily="Arial Rounded MT Bold"
                />

            <TextBlock  
                Foreground="#1DA1FF"
                Text="Click the Next button to Proceed"
                FontSize="14"
                Height="20"
                Width="300"
                TextAlignment="Center"
                Margin="0,70,0,0"
                />

            <!-- button to continue-->
            <Button 
                Height="50"
                Width="300"
                Margin="0,200,0,0"
                Content="Next"
                Click="proceed"
                Background="#0F172A"
                Foreground="#1DA1FF"
                BorderBrush="#1DA1FF"
                BorderThickness="2"
                />

        </Grid>

        <!-- Username Grid-->
        <Grid x:Name="username_grid" Visibility="Hidden">

            <Image 
                Source="/Logo50.jpg" 
                Height="200"
                Width="800"
                Margin="0,0,0,200"
                   />

            <!-- Hint message-->
            <TextBlock
                Foreground="#1DA1FF"
                Text="Enter username"
                Height="20"
                Width="270"
                TextAlignment="Justify"
                Margin="0,30,0,0"
                FontFamily="Arial Rounded MT Bold"
                />

            <!-- Enter/Prompt username-->
            <TextBox
                
                Height="40"
                Width="270"
                TextAlignment="Center"
                Margin="0,100,0,0"
                FontFamily="Arial Rounded MT Bold"
                x:Name="usernames_input"
                Background="#111827"
                Foreground="White"
                BorderBrush="#1DA1FF"
                BorderThickness="2"
                VerticalContentAlignment="Center"
                />

            <!-- error message-->
            <TextBlock
                x:Name="txtError"
                Text="please enter username to continue..."
                Height="20"
                Width="270"
                TextAlignment="Justify"
                Margin="0,180,0,0"
                Foreground="Red"
                FontFamily="Arial Rounded MT Bold"
                Visibility="Collapsed"
                />

            <!-- button to submit name-->
            <Button 
              Height="40"
              Width="270"
              Margin="0,250,0,0"
              Content="submit username"
              Click="submit_name"
              Background="#60A5FA"
              Foreground="DarkBlue"
              BorderBrush="#1DA1FF"
              BorderThickness="2"

        />

        </Grid>

        <!-- Chat Grid-->
        <Grid x:Name="chat_grid" Visibility="Hidden">


            <!-- List view to show messages show messages-->
            <ListView  
                x:Name="chats" 
                Height="400"
                Width="780"
                Margin="0,0,0,120"
                />


            <!-- TextBox to prompt questions-->
            <TextBox
                x:Name="question"
                Height="50"
                Width="480"
                Margin="0,300,300,0"
                Background="#111827"
                Foreground="White"
                BorderBrush="#1DA1FF"
                BorderThickness="2"
                VerticalContentAlignment="Center"
                />

            <!-- button to submit -->
            <Button
                Height="50"
                Width="280"
                Margin="490,300,0,0"
                Content="send "
                Click="send"
                Background="#60A5FA"
                Foreground="DarkBlue"
                BorderBrush="#1DA1FF"
                BorderThickness="2"
                />

        </Grid>

    </Grid><!--End of Parent Grid-->
</Window>
